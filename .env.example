# AmoCRM
AMO_DOMAIN=https://your-subdomain.amocrm.ru
AMO_ACCESS_TOKEN=your_access_token

# ID воронки и этапа (для сделок)
AMO_PIPELINE_ID=10582926
# Если не указать, сделка попадёт в стандартный первый этап воронки
# AMO_PIPELINE_STATUS_ID=83463326

# Секрет для проверки подписи webhook (HMAC-SHA256). Если задан — подпись обязательна (заголовок X-Signature).
WEBHOOK_SECRET=your_webhook_secret

# Порты (обязательные, без них сервер не запустится)
INTERNAL_PORT=3000
PORT=3000