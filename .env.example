# ============================================================
# AmoCRM Webhook Integration — Конфигурация
# ============================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ============================================================

# Домен вашего аккаунта amoCRM (без слеша в конце)
AMO_DOMAIN=https://yourcompany.amocrm.ru

# Токен доступа amoCRM (долгосрочный access token)
# Получить: Настройки → Интеграции → API → Ключи API
AMO_ACCESS_TOKEN=your_access_token_here

# ID воронки и этапа для новых сделок
# Получить: Настройки → Воронки → нужная воронка → F12 (Network) или через API GET /api/v4/pipelines
AMO_PIPELINE_ID=
AMO_STATUS_ID=

# ============================================================
# Опционально — ID кастомных полей контактов
# (если не указать, система найдёт поля автоматически)
# ============================================================
# AMO_PHONE_FIELD_ID=
# AMO_EMAIL_FIELD_ID=
# AMO_POSITION_FIELD_ID=

# Порт сервера (по умолчанию 3000)
# PORT=3000
# INTERNAL_PORT=3000
# EXTERNAL_PORT=3000
